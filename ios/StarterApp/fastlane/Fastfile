default_platform(:ios)

platform :ios do
  # ── Shared setup ─────────────────────────────────────────────────────────

  before_all do
    # On CI (GitHub Actions) this sets up the keychain and reads MATCH_PASSWORD
    # from the environment automatically.
    setup_ci if ENV["CI"]

    # Configure the App Store Connect API key from env vars so every lane that
    # talks to App Store Connect (produce, match, upload_to_testflight, etc.)
    # uses key-based auth instead of 2FA-blocked Apple ID password auth.
    if ENV["APP_STORE_CONNECT_API_KEY_ID"]
      app_store_connect_api_key(
        key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
        issuer_id: ENV.fetch("APP_STORE_CONNECT_API_ISSUER_ID"),
        key_content: ENV.fetch("APP_STORE_CONNECT_API_KEY_CONTENT"),
        is_key_content_base64: false,
        in_house: false
      )
    end
  end

  # ── Lanes ─────────────────────────────────────────────────────────────────

  desc "Run SwiftLint"
  lane :lint do
    swiftlint(
      mode: :lint,
      strict: true,
      config_file: ".swiftlint.yml"
    )
  end

  desc "Create the App Store Connect record and register the App ID (idempotent)"
  lane :create_app do
    produce(
      app_identifier: ENV.fetch("APP_BUNDLE_ID"),
      app_name: ENV.fetch("APP_NAME", "StarterApp"),
      language: "English",
      app_version: "1.0",
      sku: ENV.fetch("APP_BUNDLE_ID"),
      team_id: ENV.fetch("DEVELOPMENT_TEAM"),
      # skip_itc creates the App ID in the Developer Portal only;
      # set to false (default) to also create the App Store Connect record.
      skip_itc: false
    )
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    # Ensure App Store Connect record exists before trying to upload
    create_app

    match(
      type: "appstore",
      readonly: ENV["CI"] ? true : false
    )

    increment_build_number(
      build_number: ENV.fetch("GITHUB_RUN_NUMBER", Time.now.strftime("%Y%m%d%H%M"))
    )

    build_app(
      workspace: "StarterApp.xcworkspace",
      scheme: "StarterApp",
      configuration: "Release",
      export_method: "app-store",
      xcargs: "CODE_SIGNING_ALLOWED=YES CODE_SIGN_STYLE=Manual"
    )

    upload_to_testflight(
      skip_waiting_for_build_processing: true
    )
  end

  desc "Submit to the App Store (review not triggered automatically)"
  lane :release do
    create_app

    match(
      type: "appstore",
      readonly: ENV["CI"] ? true : false
    )

    increment_build_number(
      build_number: ENV.fetch("GITHUB_RUN_NUMBER", Time.now.strftime("%Y%m%d%H%M"))
    )

    build_app(
      workspace: "StarterApp.xcworkspace",
      scheme: "StarterApp",
      configuration: "Release",
      export_method: "app-store",
      xcargs: "CODE_SIGNING_ALLOWED=YES CODE_SIGN_STYLE=Manual"
    )

    upload_to_app_store(
      submit_for_review: false,
      automatic_release: false,
      force: true
    )
  end
end
