{
  "mcpServers": {
    "postgres-local": {
      "command": "bash",
      "args": [
        "scripts/mcp-postgres-local.sh"
      ]
    },
    "fetch": {
      "command": "uvx",
      "args": [
        "mcp-server-fetch"
      ]
    },
    "ios-simulator": {
      "command": "npx",
      "args": [
        "-y",
        "ios-simulator-mcp@1.6.0"
      ]
    }
  }
}
