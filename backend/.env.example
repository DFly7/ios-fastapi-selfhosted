# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/postgres

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
JWT_ACCESS_TOKEN_EXPIRE_SECONDS=3600
JWT_REFRESH_TOKEN_EXPIRE_SECONDS=2592000

# ── App ─────────────────────────────────────────────────────────────────────
APP_NAME=Starter API
ENVIRONMENT=development      # development | staging | production

# ── Logging ─────────────────────────────────────────────────────────────────
# LOG_LEVEL=DEBUG             # auto-set: DEBUG in dev, INFO in production
# LOG_JSON=false              # auto-set: false in dev, true in production
# LOG_REQUEST_BODY=true
# LOG_REQUEST_BODY_MAX_SIZE=1000

# ── CORS ─────────────────────────────────────────────────────────────────────
# ALLOWED_ORIGINS=*           # comma-separated list
# Local tightening example: http://localhost:3000,http://127.0.0.1:8000

# ── Rate limiting ────────────────────────────────────────────────────────────
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_DEFAULT=100/minute

# ── Observability ────────────────────────────────────────────────────────────
# Prometheus metrics at GET /metrics (off unless you set this)
# ENABLE_METRICS=true
# SENTRY_DSN=https://your-key@sentry.io/your-project
# SENTRY_ENVIRONMENT=development   # defaults to ENVIRONMENT if unset
# SENTRY_TRACES_SAMPLE_RATE=0.1

# ── RevenueCat ────────────────────────────────────────────────────────────────
# Shared secret for the POST /api/v1/webhooks/revenuecat endpoint.
# Set the same value in RevenueCat dashboard → Project → Integrations → Webhooks.
# REVENUECAT_WEBHOOK_SECRET=your_revenuecat_webhook_secret

# ── Email (Resend) ────────────────────────────────────────────────────────────
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=onboarding@yourdomain.com

# ── Production overrides (examples) ─────────────────────────────────────────
# ENVIRONMENT=production
# LOG_LEVEL=INFO
# LOG_JSON=true
# ALLOWED_ORIGINS=https://your-production-domain.com
