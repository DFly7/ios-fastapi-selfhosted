# ── Required ────────────────────────────────────────────────────────────────
# Local Docker: `supabase start` → `supabase status` (anon key + API URL)
SUPABASE_URL=http://host.docker.internal:54321
# Hosted: SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLIC_ANON_KEY=your-anon-key-here

# ── App ─────────────────────────────────────────────────────────────────────
APP_NAME=Starter API
ENVIRONMENT=development      # development | staging | production

# ── Logging ─────────────────────────────────────────────────────────────────
# LOG_LEVEL=DEBUG             # auto-set: DEBUG in dev, INFO in production
# LOG_JSON=false              # auto-set: false in dev, true in production
# LOG_REQUEST_BODY=true
# LOG_REQUEST_BODY_MAX_SIZE=1000

# ── CORS ─────────────────────────────────────────────────────────────────────
# ALLOWED_ORIGINS=*           # comma-separated list
# Local tightening example: http://localhost:3000,http://127.0.0.1:8000

# ── Rate limiting ────────────────────────────────────────────────────────────
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_DEFAULT=100/minute

# ── Observability ────────────────────────────────────────────────────────────
# Prometheus metrics at GET /metrics (off unless you set this)
# ENABLE_METRICS=true
# SENTRY_DSN=https://your-key@sentry.io/your-project
# SENTRY_ENVIRONMENT=development   # defaults to ENVIRONMENT if unset
# SENTRY_TRACES_SAMPLE_RATE=0.1

# ── RevenueCat ────────────────────────────────────────────────────────────────
# Shared secret for the POST /api/v1/webhooks/revenuecat endpoint.
# Set the same value in RevenueCat dashboard → Project → Integrations → Webhooks.
# REVENUECAT_WEBHOOK_SECRET=your_revenuecat_webhook_secret

# Supabase service role key — used by the webhook to update profiles.is_pro,
# bypassing RLS. Find it in Supabase dashboard → Settings → API → service_role key.
# NEVER expose this key client-side.
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── Email (Resend) ────────────────────────────────────────────────────────────
# RESEND_API_KEY is used by FastAPI for app-level transactional email AND as the
# SMTP password when Supabase auth emails are routed through Resend (see README).
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=onboarding@yourdomain.com
# SMTP_FROM_EMAIL=onboarding@yourdomain.com   # sender address for Supabase auth emails (local SMTP)

# ── Production overrides (examples) ─────────────────────────────────────────
# ENVIRONMENT=production
# LOG_LEVEL=INFO
# LOG_JSON=true
# ALLOWED_ORIGINS=https://your-production-domain.com
